# AWS Lambda + S3 Configuration for CARE Compass
# Copy this file to aws/deployment/.env.dev and aws/deployment/.env.prod
# Fill in your values

# ==================== AWS CONFIGURATION ====================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012  # Your AWS Account ID
ENVIRONMENT=dev  # dev or prod

# ==================== APP CONFIGURATION ====================
GOOGLE_API_KEY=your_google_generative_ai_key_here
LAMBDA_MEMORY=1024
LAMBDA_TIMEOUT=300

# ==================== S3 BUCKET NAMES ====================
# These will be auto-generated as: care-compass-{type}-{account-id}-{environment}
# But you can override them here if needed
S3_DOCUMENTS_BUCKET=care-compass-documents-{account_id}-{environment}
S3_PROCESSED_BUCKET=care-compass-processed-{account_id}-{environment}
S3_VECTORDB_BUCKET=care-compass-vectordb-{account_id}-{environment}

# ==================== DEPLOYMENT CONFIGURATION ====================
STACK_NAME=care-compass-stack-${ENVIRONMENT}
CAPABILITIES=CAPABILITY_IAM
OUTPUT_FILE=deployment-outputs.json
