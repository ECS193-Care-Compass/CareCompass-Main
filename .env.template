# Care Compass .env Template
# Copy this file to `.env` and fill in the values as needed.
# See the README for detailed explanations of each variable.

# =====================
# GCP (Google Cloud Platform)
# =====================
GCP_PROJECT_ID=
GCP_REGION=
GCP_SERVICE_ACCOUNT_JSON=./gcp-key.json

# =====================
# AWS (Amazon Web Services)
# =====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

S3_DOCUMENTS_BUCKET=
S3_VECTORDB_BUCKET=
S3_LOGS_BUCKET=

# =====================
# Vertex AI / Model
# =====================
VERTEX_MODEL_NAME=gemini-pro
VERTEX_LOCATION=us-central1

# =====================
# Lambda / Serverless
# =====================
LAMBDA_FUNCTION_NAME=
LAMBDA_ROLE_ARN=

# =====================
# Cache
# =====================
DYNAMODB_TABLE_NAME=
CACHE_TTL_SECONDS=3600

# =====================
# Deployment
# =====================
ENVIRONMENT=dev

# =====================
# Other
# =====================

# LOG_LEVEL controls the verbosity of backend logging.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Example: Set to DEBUG for detailed logs during development, or ERROR for only errors in production.
# Common values:
#   LOG_LEVEL=DEBUG     # Most verbose, shows all debug info
#   LOG_LEVEL=INFO      # Default, shows general info and warnings/errors
#   LOG_LEVEL=WARNING   # Only warnings and errors
#   LOG_LEVEL=ERROR     # Only errors
#   LOG_LEVEL=CRITICAL  # Only critical errors
LOG_LEVEL=INFO


# This template is safe to share.
