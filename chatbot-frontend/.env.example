# Frontend Environment Variables
# Copy to chatbot-frontend/.env and update accordingly

# Development (local FastAPI)
VITE_API_BASE_URL=http://localhost:8000

# Production (AWS Lambda)
# VITE_API_BASE_URL=https://your-api-id.lambda-url.us-east-1.on.aws

# Optional: Set to 'true' to enable verbose logging
VITE_DEBUG=false
