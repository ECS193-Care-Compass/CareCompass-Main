# CARE Compass Environment Configuration
# Copy this to .env and fill in your values

# ==================== GOOGLE AI API ====================
GOOGLE_API_KEY=your_gemini_api_key_here

# ==================== AWS CONFIGURATION ====================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=432732422396
ENVIRONMENT=dev

# ==================== S3 BUCKET NAMES ====================
S3_DOCUMENTS_BUCKET=care-compass-documents-432732422396-dev
S3_VECTORDB_BUCKET=care-compass-vectordb-432732422396-dev
S3_LOGS_BUCKET=care-compass-logs-432732422396-dev

# ==================== MODEL CONFIGURATION ====================
MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.7
TOP_K=3

# ==================== LAMBDA CONFIGURATION ====================
LAMBDA_MEMORY=1024
LAMBDA_TIMEOUT=300

# ==================== DEPLOYMENT CONFIGURATION ====================
STACK_NAME=care-compass-stack-dev
CAPABILITIES=CAPABILITY_IAM
OUTPUT_FILE=deployment-outputs.json
