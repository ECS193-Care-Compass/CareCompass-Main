# CARE Compass Environment Configuration
# Copy this to .env and fill in your values

# ==================== GOOGLE AI API ====================
GOOGLE_API_KEY=your_gemini_api_key_here

# ==================== AWS CREDENTIALS ====================
# Get these from AWS IAM → Users → Security credentials → Access keys
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ==================== AWS CONFIGURATION ====================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id_here
ENVIRONMENT=dev

# ==================== S3 BUCKET NAMES ====================
# Format: care-compass-{type}-{account_id}-{environment}
S3_DOCUMENTS_BUCKET=care-compass-documents-YOUR_ACCOUNT_ID-dev
S3_VECTORDB_BUCKET=care-compass-vectordb-YOUR_ACCOUNT_ID-dev
S3_LOGS_BUCKET=care-compass-logs-YOUR_ACCOUNT_ID-dev

# ==================== MODEL CONFIGURATION ====================
MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.7
TOP_K=3

# ==================== LAMBDA CONFIGURATION ====================
LAMBDA_MEMORY=1024
LAMBDA_TIMEOUT=300

# ==================== DEPLOYMENT CONFIGURATION ====================
STACK_NAME=care-compass-stack-dev
CAPABILITIES=CAPABILITY_IAM
OUTPUT_FILE=deployment-outputs.json
